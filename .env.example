# ============================================================
#  Telegram Marketing CRM — environment configuration
#  Copy to `.env` and adjust. Never commit the real .env.
# ============================================================

# ---- App ----
APP_NAME=Telegram Marketing CRM
APP_VERSION=0.1.0
ENVIRONMENT=development          # development | production
DEBUG=true

# ---- API / Auth ----
API_HOST=0.0.0.0
API_PORT=8000
# Generate a strong value for production:
#   openssl rand -hex 32   (or:  docker compose run --rm backend python -m app.cli generate-secret)
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Comma-separated list of allowed origins, or * for all (dev only).
# In production set this to your domain, e.g. https://crm.example.com
CORS_ORIGINS=*

# ---- Security / hardening (Phase 12) ----
# Per-client-IP request rate limiting for /api/* (fixed window).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=240          # global cap per IP
RATE_LIMIT_LOGIN_PER_MINUTE=10     # tighter cap on auth endpoints (brute-force)
RATE_LIMIT_WINDOW_SECONDS=60
# Security response headers (nosniff, frame-deny, HSTS, ...).
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000

# ---- Bootstrap admin (created on first startup by `app.cli ensure-admin`) ----
# CHANGE THESE before first run in production.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin12345
BOOTSTRAP_ADMIN_NAME=Administrator

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm
POSTGRES_DB=telegram_crm

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---- Telegram (shared API credentials — get from https://my.telegram.org) ----
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ---- Telegram Engine Service ----
# Internal URL the backend uses to reach the engine (Docker service name).
ENGINE_URL=http://engine:9100
ENGINE_TIMEOUT_SECONDS=30
# Directory where the engine persists Telethon session files (mounted volume).
SESSIONS_DIR=./sessions

# ---- Caddy / reverse proxy ----
# For local dev leave as :80. For production set to your domain (auto HTTPS),
# e.g. CADDY_SITE_ADDRESS=crm.example.com
CADDY_SITE_ADDRESS=:80

# ---- Backups (production `backup` service) ----
# Interval between pg_dump runs and how long to keep dumps (see scripts/backup.sh).
BACKUP_INTERVAL_SECONDS=86400      # daily
BACKUP_RETENTION_DAYS=14
