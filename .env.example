# ============================================================
#  Telegram Marketing CRM — environment configuration
#  Copy to `.env` and adjust. Never commit the real .env.
# ============================================================

# ---- App ----
APP_NAME=Telegram Marketing CRM
APP_VERSION=0.1.0
ENVIRONMENT=development          # development | production
DEBUG=true

# ---- API / Auth ----
API_HOST=0.0.0.0
API_PORT=8000
# Generate a strong value for production, e.g. `openssl rand -hex 32`
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Comma-separated list of allowed origins, or * for all (dev only)
CORS_ORIGINS=*

# ---- Bootstrap admin (created on first startup by `app.cli ensure-admin`) ----
# CHANGE THESE before first run in production.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin12345
BOOTSTRAP_ADMIN_NAME=Administrator

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm
POSTGRES_DB=telegram_crm

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---- Telegram (shared API credentials — filled in Phase 2) ----
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ---- Caddy / reverse proxy ----
# For local dev leave as :80. For production set to your domain (auto HTTPS),
# e.g. CADDY_SITE_ADDRESS=crm.example.com
CADDY_SITE_ADDRESS=:80
